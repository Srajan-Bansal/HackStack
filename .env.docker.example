# ========================
# PostgreSQL
# ========================
POSTGRES_USER=hackstack
POSTGRES_PASSWORD=changeme
POSTGRES_DB=hackstack

# ========================
# Redis
# ========================
REDIS_PASSWORD=changeme

# ========================
# JWT (http-backend)
# ========================
JWT_SECRET=your-jwt-secret-here
JWT_COOKIE_EXPIRES_IN=604800000
JWT_EXPIRES_IN=7d
JWT_SALT_ROUNDS=10

# ========================
# Cookies
# ========================
# Set to true when using HTTPS (e.g., behind a reverse proxy)
COOKIE_SECURE=false

# ========================
# URLs
# ========================
VITE_BACKEND_URL=http://localhost:3000
FRONTEND_URL=http://localhost

# ========================
# Ports
# ========================
BACKEND_PORT=3000
WEBHOOK_PORT=3001
