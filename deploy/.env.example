# Required environment variables for deploy/docker-compose.prod.yml
# Copy to .env and fill in values before deploying.

# Database (RDS endpoint)
DATABASE_URL=postgresql://hackstack:<password>@<rds-endpoint>:5432/hackstack

# Redis (ElastiCache endpoint) - two formats needed
REDIS_URL=redis://<elasticache-endpoint>:6379
REDIS_HOST=<elasticache-endpoint>

# Kafka (private IP of Kafka EC2)
KAFKA_BROKER=<kafka-private-ip>:9092

# Auth
JWT_SECRET=<generate-a-strong-secret>

# Frontend (CloudFront distribution URL)
FRONTEND_URL=https://<cloudfront-domain>.cloudfront.net
